---
title: WaiterList structure
---
graph LR
    subgraph WaiterList
        HEAD["head"]
        TAIL["tail"]
    end

    A["WaiterNode A<br/>prev: null"]
    B["WaiterNode B"]
    C["WaiterNode C<br/>next: null"]

    HEAD --> A
    A -- "next" --> B
    B -- "next" --> C
    B -- "prev" --> A
    C -- "prev" --> B
    TAIL --> C
